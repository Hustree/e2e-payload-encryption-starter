# Copy to .env.local and adjust as needed.
# Create React App exposes REACT_APP_* vars to the browser at build time.

REACT_APP_API_URL=http://localhost:8080

# POC-only symmetric key used by the legacy AES-CBC demo path.
# NOT used by the JWE flow. Must match backend `encryption.key` in application.properties.
# Remove before any non-demo deployment.
REACT_APP_ENCRYPTION_KEY=my-super-secret-aes-256-key-32ch
